@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="row mb-4">
    <div class="col-lg-12">
        <h1 class="mb-4">Admin Dashboard</h1>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <h5>Total Members</h5>
            <div class="number">@ViewBag.TotalMembers</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <h5>Total Trainers</h5>
            <div class="number">@ViewBag.TotalTrainers</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <h5>Total Packages</h5>
            <div class="number">@ViewBag.TotalPackages</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <h5>Total Classes</h5>
            <div class="number">@ViewBag.TotalClasses</div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Recent Payments</h5>
            </div>
            <div class="card-body">
                @if (ViewBag.RecentPayments?.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Member</th>
                                    <th>Amount</th>
                                    <th>Method</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var payment in ViewBag.RecentPayments)
                                {
                                    <tr>
                                        <td>@payment.Member?.User?.FullName</td>
                                        <td>
                                            <strong>@payment.Amount.ToString("C")</strong>
                                        </td>
                                        <td>@payment.PaymentMethod</td>
                                        <td>@payment.PaymentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            <span class="badge badge-success">@payment.Status</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No payments recorded yet.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Quick Actions</h5>
            </div>
            <div class="card-body">
                <a href="/Admin/Members" class="btn btn-outline-primary w-100 mb-2">Manage Members</a>
                <a href="/Admin/Trainers" class="btn btn-outline-primary w-100 mb-2">Manage Trainers</a>
                <a href="/Admin/Packages" class="btn btn-outline-primary w-100 mb-2">Manage Packages</a>
                <a href="/Admin/Classes" class="btn btn-outline-primary w-100 mb-2">Manage Classes</a>
                <a href="/Admin/Payments" class="btn btn-outline-primary w-100 mb-2">View Payments</a>
                <a href="/Admin/Reports" class="btn btn-outline-primary w-100">View Reports</a>
            </div>
        </div>
    </div>
</div>
